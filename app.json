{
  "expo": {
    "name": "TripKart",
    "slug": "tripkart-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tripkart",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7C2D12"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "TripKart needs camera access to scan QR codes and capture photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon.png",
          "color": "#5C1615",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TripKart needs access to your photos to upload images.",
          "cameraPermission": "TripKart needs camera access to take photos."
        }
      ],
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.svg",
      "name": "TripKart",
      "shortName": "BK",
      "description": "Sacred pilgrimage booking platform",
      "themeColor": "#5C1615",
      "backgroundColor": "#5C1615"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9d65c70a-cf6c-4ad2-bae9-8c95a7e25980"
      }
    },
    "android": {
      "package": "com.rishabh8233.tripkart",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#3D0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.rishabh8233.tripkart",
      "supportsTablet": true
    },
    "owner": "rishabh8233"
  }
}
