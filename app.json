{
  "expo": {
    "name": "Book Yatra",
    "slug": "book-yatra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookyatra",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "icon": "./assets/app-icon.png",
    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3D0A0A"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Book Yatra needs camera access to scan QR codes and capture photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon.png",
          "color": "#5C1615",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Book Yatra needs access to your photos to upload images.",
          "cameraPermission": "Book Yatra needs camera access to take photos."
        }
      ],
      "expo-local-authentication"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.svg",
      "name": "Book Yatra",
      "shortName": "BK",
      "description": "Sacred pilgrimage booking platform",
      "themeColor": "#5C1615",
      "backgroundColor": "#5C1615"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e68c5a74-98fb-490c-acaf-408352457a61"
      }
    },
    "android": {
      "package": "com.rishabh8233.bookyatramobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#3D0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.rishabh8233.bookyatramobile",
      "supportsTablet": true
    }
  }
}
