{
  "expo": {
    "name": "Book Yatra",
    "slug": "book-yatra-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "bookyatra",
    "jsEngine": "jsc",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "icon": "./assets/khatuShyamJiWallpapers.png",
    "splash": {
      "image": "./assets/khatuShyamJiWallpapers.png",
      "resizeMode": "contain",
      "backgroundColor": "#5C1615"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": false
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.svg",
      "name": "Book Yatra",
      "shortName": "BK",
      "description": "Sacred pilgrimage booking platform",
      "themeColor": "#5C1615",
      "backgroundColor": "#5C1615"
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e68c5a74-98fb-490c-acaf-408352457a61"
      }
    },
    "android": {
      "package": "com.rishabh8233.bookyatramobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/khatuShyamJiWallpapers.png",
        "backgroundColor": "#5C1615"
      }
    },
    "ios": {
      "bundleIdentifier": "com.rishabh8233.bookyatramobile",
      "supportsTablet": true
    }
  }
}
